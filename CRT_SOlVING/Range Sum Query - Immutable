class NumArray {

        int[] prfx;
    public NumArray(int[] nums) {
        prfx=new int[nums.length+1];
        for(int i=1;i<nums.length+1;i++){
            prfx[i]=nums[i-1]+prfx[i-1];
            System.out.println(prfx[i]);
        }
    }
    
    public int sumRange(int left, int right) {
        return prfx[right+1]-prfx[left];
    }
}

