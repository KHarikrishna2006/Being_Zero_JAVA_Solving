class Solution {
    public int firstMissingPositive(int[] nums) {
        Arrays.sort(nums);
        int i=0;
        while(i<nums.length && nums[i]<0 ){
            i++;
        }
        if(i<nums.length && nums[i]==0) i++;
        System.out.println(i);
        int t=1;
        for(int j=i;j<nums.length;j++){
            if(t==nums[j]) t++;
            else if(nums[j]>t) return t;
        }
        System.out.println(t);
        return t;
    }
}
